{
  "name": "xiaop-liquid-glass",
  "version": "3.0.0",
  "description": "XiaoP Liquid Glass v3.0 — 终极液态玻璃设计系统，融合所有最佳实践。8种SDF折射模式、20+交互效果、50+组件、TypeScript支持、零依赖",
  "type": "module",
  "main": "dist/liquid-glass.cjs.js",
  "module": "dist/liquid-glass.esm.js",
  "browser": "dist/liquid-glass.js",
  "types": "dist/liquid-glass.d.ts",
  "style": "dist/liquid-glass.css",
  "files": [
    "dist/",
    "src/",
    "demos/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "dev": "npm run build:watch & npx serve . -p 3000",
    "demo": "npx serve . -p 3000",
    "docs": "npx serve docs -p 8080",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "liquid-glass",
    "glassmorphism",
    "glass-effect",
    "css-framework",
    "ui-design",
    "ios26",
    "apple-design",
    "frosted-glass",
    "translucent",
    "skeuomorphic",
    "svg-filters",
    "backdrop-filter",
    "canvas",
    "css-variables",
    "sdf",
    "vanilla-js"
  ],
  "author": "XiaoP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaop-coder/xiaop-liquid-glass"
  },
  "homepage": "https://xiaop-coder.github.io/xiaop-liquid-glass",
  "bugs": {
    "url": "https://github.com/xiaop-coder/xiaop-liquid-glass/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "rollup": "^4.12.0"
  }
}
